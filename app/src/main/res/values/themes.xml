<?xml version="1.0" encoding="utf-8"?>
<!--
    File: themes.xml
    Deskripsi: Tema utama aplikasi Seminar Registration App
    Base Theme: Theme.MaterialComponents.Light.NoActionBar
    Palet: Indigo (#5C6BC0) + Amber (#FFB300) + Teal (#00897B)
-->
<resources>

    <!-- ── Base Application Theme ─────────────────────────────────────────── -->
    <style name="Base.Theme.RegisterApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="android:colorBackground">@color/bg_main</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorError">@color/error</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_hint</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/bg_main</item>
    </style>

    <!-- ── Main Theme ─────────────────────────────────────────────────────── -->
    <style name="Theme.RegisterApp" parent="Base.Theme.RegisterApp" />

    <!-- ── TextInputLayout Style Override ────────────────────────────────── -->
    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- ── Custom AlertDialog Style ─────────────────────────────────────── -->
    <style name="CustomAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/AlertDialogTitleStyle</item>
        <item name="android:background">@color/white</item>
        <item name="shapeAppearanceMediumComponent">@style/AlertDialogShape</item>
    </style>

    <style name="AlertDialogTitleStyle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="AlertDialogShape" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">20dp</item>
    </style>

    <!-- ── Button Styles ────────────────────────────────────────────────── -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- ── Tab Layout Text Style ─────────────────────────────────────────── -->
    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">12sp</item>
        <item name="textAllCaps">false</item>
    </style>

</resources>
