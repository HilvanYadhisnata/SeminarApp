<?xml version="1.0" encoding="utf-8"?>
<!-- bg_radio_selected.xml - State list drawable untuk RadioButton selected state -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State: checked/selected -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="@color/primary_dark" />
        </shape>
    </item>
    <!-- State: pressed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_light" />
            <corners android:radius="10dp" />
            <stroke android:width="1.5dp" android:color="@color/primary" />
        </shape>
    </item>
    <!-- State: default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_very_light" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="@color/primary_light" />
        </shape>
    </item>
</selector>
