<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_form.xml
    Deskripsi: Form Pendaftaran Seminar dengan Material Design
    Komponen: TextInputLayout (Nama, Email, HP), RadioGroup, Spinner, CheckBox, Button
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_form"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main"
    tools:context=".FormActivity">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- HEADER                                                           -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="20dp">

        <!-- Tombol Back -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_icon_circle"
            android:padding="8dp"
            app:tint="@color/white"
            android:contentDescription="Kembali"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendaftaran Seminar"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:fontFamily="sans-serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Isi form berikut dengan lengkap"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- SCROLLABLE FORM CONTENT                                          -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── SECTION: Data Diri ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤  Data Diri"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp" />

                    <!-- Input: Nama Lengkap -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nama Lengkap" android:textSize="12sp" android:textColor="@color/text_body"
                        android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_nama"
                        style="@style/CustomTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/primary"
                        android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_nama"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Masukkan nama lengkap Anda"
                            android:inputType="textPersonName|textCapWords"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif"
                            android:paddingVertical="14dp"
                            android:background="@null" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Input: Email -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Email" android:textSize="12sp" android:textColor="@color/text_body"
                        android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_email_form"
                        style="@style/CustomTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/primary"
                        android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email_form"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="contoh@email.com"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif"
                            android:paddingVertical="14dp"
                            android:background="@null" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Input: Nomor HP -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nomor HP" android:textSize="12sp" android:textColor="@color/text_body"
                        android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_phone"
                        style="@style/CustomTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="@color/primary"
                        app:helperText="Diawali 08 | 10-13 digit | hanya angka"
                        app:helperTextTextColor="@color/text_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_phone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="08xxxxxxxxxx"
                            android:inputType="phone"
                            android:maxLength="13"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif"
                            android:paddingVertical="14dp"
                            android:background="@null" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SECTION: Jenis Kelamin ───────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚻  Jenis Kelamin"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp" />

                    <RadioGroup
                        android:id="@+id/rg_gender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_laki"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:text="♂  Laki-laki"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:background="@drawable/bg_radio_selected"
                            android:button="@null"
                            android:layout_marginEnd="8dp" />

                        <RadioButton
                            android:id="@+id/rb_perempuan"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:text="♀  Perempuan"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:background="@drawable/bg_radio_selected"
                            android:button="@null"
                            android:layout_marginStart="8dp" />
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SECTION: Pilihan Seminar ─────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎓  Pilih Seminar"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp" />

                    <Spinner
                        android:id="@+id/spinner_seminar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_spinner"
                        android:paddingHorizontal="16dp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SECTION: Persetujuan ─────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary_very_light"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_setuju"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonTint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Saya menyetujui bahwa data yang saya input adalah benar dan dapat dipertanggungjawabkan."
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/text_body"
                        android:layout_marginStart="12dp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tombol Submit -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Submit Pendaftaran"
                android:textColor="@color/white"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
