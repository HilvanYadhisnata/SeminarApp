<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: item_data_row.xml
    Deskripsi: Baris data reusable untuk halaman sukses
    Catatan: Layout ini sebagai reference; baris aktual di-inline di activity_success.xml
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/tvRowIcon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="📌"
        android:textSize="18sp"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp">

        <TextView
            android:id="@+id/tvRowLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Label"
            android:textColor="#9098B1"
            android:textSize="11sp"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/tvRowValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Value"
            android:textColor="#2D3748"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

</LinearLayout>
