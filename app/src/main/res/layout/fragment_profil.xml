<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: fragment_profil.xml
    Deskripsi: Tab Profil - menampilkan info user dan tombol logout
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Avatar dan Nama -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/primary"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_header_gradient"
                android:padding="28dp"
                android:gravity="center">

                <!-- Avatar Circle -->
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="👤"
                    android:textSize="36sp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_circle"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tv_profil_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama User"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tv_profil_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="user@email.com"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:textColor="#B3FFFFFF"
                    android:layout_marginTop="4dp" />

                <!-- Badge Status -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓  Mahasiswa Aktif"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:fontFamily="sans-serif-medium"
                    android:background="@color/white"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:layout_marginTop="16dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informasi Akun"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- Row Info: Universitas -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏫" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Universitas" android:textSize="11sp" android:fontFamily="sans-serif" android:textColor="@color/text_hint" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Universitas Teknologi Bandung" android:textSize="14sp" android:fontFamily="sans-serif-medium" android:textColor="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <!-- Row Info: Kelas -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📚" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kelas" android:textSize="11sp" android:fontFamily="sans-serif" android:textColor="@color/text_hint" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TIF K 24A" android:textSize="14sp" android:fontFamily="sans-serif-medium" android:textColor="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <!-- Row Info: Mata Kuliah -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📱" android:textSize="18sp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mata Kuliah" android:textSize="11sp" android:fontFamily="sans-serif" android:textColor="@color/text_hint" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pemrograman Mobile I" android:textSize="14sp" android:fontFamily="sans-serif-medium" android:textColor="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tombol Logout -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🚪  Keluar / Logout"
            android:textSize="15sp"
            android:textColor="@color/error"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/error_light"
            app:strokeColor="@color/error"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
