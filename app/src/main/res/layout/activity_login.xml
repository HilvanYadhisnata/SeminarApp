<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_login.xml
    Deskripsi: Halaman login dengan gradient Indigo, CardView, dan animasi
    Konsisten dengan tema RegisterApp (Indigo #5C6BC0)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_login"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_header_gradient"
    tools:context=".LoginActivity">

    <!-- Dekorasi Lingkaran Kanan Atas -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_icon_circle"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp" />

    <!-- Dekorasi Lingkaran Kiri Bawah -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_icon_circle"
        android:alpha="0.10"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="-40dp"
        android:layout_marginStart="-40dp" />

    <!-- Logo / Icon Aplikasi -->
    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:src="@drawable/ic_app_logo"
        android:background="@drawable/bg_icon_circle"
        android:padding="16dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="72dp"
        app:tint="@color/white" />

    <!-- Judul Selamat Datang -->
    <TextView
        android:id="@+id/tv_welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selamat Datang!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.02"
        app:layout_constraintTop_toBottomOf="@id/iv_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- Sub-Judul -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Masuk untuk melanjutkan"
        android:textSize="14sp"
        android:textColor="#B3FFFFFF"
        android:fontFamily="sans-serif"
        app:layout_constraintTop_toBottomOf="@id/tv_welcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />

    <!-- Card Container Login -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_login"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Label Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="13sp"
                android:textColor="@color/text_body"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:layout_marginBottom="8dp" />

            <!-- Input Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_email"
                style="@style/CustomTextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/primary"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan email Anda"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif"
                    android:paddingVertical="14dp"
                    android:background="@null" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Label Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="13sp"
                android:textColor="@color/text_body"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp" />

            <!-- Input Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_password"
                style="@style/CustomTextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/primary"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/primary"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan password Anda"
                    android:inputType="textPassword"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif"
                    android:paddingVertical="14dp"
                    android:background="@null" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Lupa Password -->
            <TextView
                android:id="@+id/tv_forgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lupa Password?"
                android:textSize="13sp"
                android:textColor="@color/primary"
                android:fontFamily="sans-serif-medium"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:padding="4dp" />

            <!-- Tombol Login -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_login"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Sign In"
                android:textColor="@color/white"
                android:layout_marginTop="24dp" />

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  atau masuk dengan  "
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider" />
            </LinearLayout>

            <!-- Tombol Google (dekoratif) -->
            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Lanjutkan dengan Google"
                android:textColor="@color/text_body"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                app:icon="@drawable/ic_email"
                app:iconTint="@color/primary"
                app:iconGravity="textStart"
                app:backgroundTint="@color/primary_very_light"
                app:strokeColor="@color/primary_light"
                app:strokeWidth="1dp"
                app:cornerRadius="14dp"
                android:layout_marginTop="12dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Row Sign Up -->
    <LinearLayout
        android:id="@+id/ll_signup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/card_login"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belum punya akun? "
            android:textSize="14sp"
            android:textColor="#B3FFFFFF"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/tv_signup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daftar Sekarang"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:fontFamily="sans-serif"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
