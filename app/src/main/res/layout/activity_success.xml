<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_success.xml
    Deskripsi: Halaman sukses registrasi dengan ringkasan data
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- SUCCESS HEADER                                                    -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_success_gradient"
            android:orientation="vertical"
            android:paddingTop="64dp"
            android:paddingBottom="40dp"
            android:paddingHorizontal="24dp"
            android:gravity="center">

            <!-- Ikon Centang -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_check_circle"
                android:background="@drawable/bg_success_icon"
                android:padding="16dp"
                android:layout_marginBottom="20dp" />

            <!-- Teks Selamat -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registrasi Berhasil! 🎉"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Akun Anda telah berhasil dibuat"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Wave -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:src="@drawable/wave_success"
            android:scaleType="fitXY"
            android:layout_marginTop="-2dp" />

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- DATA SUMMARY CARD                                                 -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋  Ringkasan Data"
                    android:textColor="@color/success"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_success_label"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="20dp" />

                <!-- Nama -->
                <include layout="@layout/item_data_row"
                    android:id="@+id/rowNama" />

                <!-- Baris data dibuat secara inline untuk setiap field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="👤"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nama Lengkap"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif" />

                        <TextView
                            android:id="@+id/tvNamaSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="@color/text_body"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginVertical="2dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:layout_marginBottom="2dp">

                    <TextView android:layout_width="28dp" android:layout_height="28dp" android:text="📧" android:textSize="18sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email" android:textColor="@color/text_hint" android:textSize="11sp" android:fontFamily="sans-serif" />
                        <TextView android:id="@+id/tvEmailSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="@color/text_body" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginVertical="2dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:layout_marginBottom="2dp">

                    <TextView android:layout_width="28dp" android:layout_height="28dp" android:text="⚧" android:textSize="18sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jenis Kelamin" android:textColor="@color/text_hint" android:textSize="11sp" android:fontFamily="sans-serif" />
                        <TextView android:id="@+id/tvGenderSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="@color/text_body" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginVertical="2dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="12dp"
                    android:layout_marginBottom="2dp">

                    <TextView android:layout_width="28dp" android:layout_height="28dp" android:text="🏙️" android:textSize="18sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kota Asal" android:textColor="@color/text_hint" android:textSize="11sp" android:fontFamily="sans-serif" />
                        <TextView android:id="@+id/tvKotaSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="@color/text_body" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginVertical="2dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:paddingVertical="12dp">

                    <TextView android:layout_width="28dp" android:layout_height="28dp" android:text="🎯" android:textSize="18sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hobi" android:textColor="@color/text_hint" android:textSize="11sp" android:fontFamily="sans-serif" />
                        <TextView android:id="@+id/tvHobiSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textColor="@color/text_body" android:textSize="14sp" android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- ACTION BUTTONS                                                    -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDashboard"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🏠  Ke Dashboard"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="@color/success"
                app:cornerRadius="16dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKembali"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="← Daftar Akun Lain"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                app:strokeColor="@color/success"
                app:strokeWidth="1.5dp"
                android:textColor="@color/success"
                app:cornerRadius="16dp"
                app:rippleColor="@color/success_light" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
